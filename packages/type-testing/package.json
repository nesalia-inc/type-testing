{
  "name": "@deessejs/type-testing",
  "version": "0.3.4",
  "type": "module",
  "description": "A micro library for compile-time type testing in TypeScript",
  "keywords": ["typescript", "types", "testing", "type-testing", "vitest", "assertions"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://types.deessejs.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/nesalia-inc/type-testing.git"
  },
  "bugs": {
    "url": "https://github.com/nesalia-inc/type-testing/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vitest": {
      "import": "./dist/vitest/index.js",
      "types": "./dist/vitest/index.d.ts"
    },
    "./vitest/setup": {
      "import": "./dist/vitest/setup.js",
      "types": "./dist/vitest/setup.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.9"
  }
}
